// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DropStatus {
  UPCOMING
  LIVE
  ENDED
}

enum ReservationStatus {
  ACTIVE
  EXPIRED
  COMPLETED
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  reservations Reservation[]
  purchases    Purchase[]
  createdAt    DateTime      @default(now())
}

model Sneaker {
  id        String   @id @default(cuid())
  name      String
  brand     String
  imageUrl  String?
  createdAt DateTime @default(now())
  drops     Drop[]
}

model Drop {
  id             String        @id @default(cuid())
  sneakerId      String
  sneaker        Sneaker       @relation(fields: [sneakerId], references: [id])
  releaseAt      DateTime
  retailPrice    Float
  totalStock     Int
  availableStock Int
  reservedStock  Int           @default(0)
  soldStock      Int           @default(0)
  status         DropStatus    @default(UPCOMING)
  reservations   Reservation[]
  purchases      Purchase[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, releaseAt])
  @@index([availableStock])  // Optimizes stock availability checks in reserve
}

model Reservation {
  id        String            @id @default(cuid())
  dropId    String
  drop      Drop              @relation(fields: [dropId], references: [id])
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime
  createdAt DateTime          @default(now())
  purchase  Purchase?

  @@index([dropId, status])     // Optimizes purchase reservation lookup
  @@index([status, expiresAt])  // Optimizes expired reservation cleanup queries
}

model Purchase {
  id            String      @id @default(cuid())
  dropId        String
  drop          Drop        @relation(fields: [dropId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  createdAt     DateTime    @default(now())

  @@index([dropId, createdAt])  // Optimizes recent purchases query in getActiveDrops
  @@index([userId])             // Optimizes user purchase history queries
}
